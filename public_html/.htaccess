RewriteEngine On
Options -Indexes

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.kubera-dom\.ru$ [NC]
RewriteRule ^ https://kubera-dom.ru%{REQUEST_URI} [R=301,L,NE]

<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=(), accelerometer=(), autoplay=(), gyroscope=(), magnetometer=(), midi=(), sync-xhr=()"
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    Header always set X-Permitted-Cross-Domain-Policies "none"
</IfModule>

RewriteRule ^(app|data)/ - [F,L]
RewriteRule (^|/)\. - [F,L]
RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|README\.md)$ - [F,L,NC]
RewriteRule ^(uploads|assets)/.*\.(php[0-9]?|phtml|phar|pl|py|cgi|asp|aspx|jsp|sh)$ - [F,L,NC]
RewriteRule \.(bak|backup|conf|config|csv|dist|ini|log|old|orig|save|sql|sqlite|swp|toml|tmp|tsv|ya?ml)$ - [F,L,NC]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
